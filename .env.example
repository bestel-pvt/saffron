# ─── Saffron & Co Environment Variables ──────────────────────────────────────
# Copy to .env for local dev. Set in Railway/Vercel/etc for production.
# NEVER commit .env (gitignored).

PORT=3001

# Used ONCE on first server startup to seed admin user (bcrypt-hashed into db.json)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password_here

# JWT signing secret — openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-32-chars-min

# Persistent storage paths (Railway volume, etc).
# Defaults: server/data/, server/uploads/payment-proofs/
# DB_DIR=/data
# UPLOAD_DIR=/data/payment-proofs
